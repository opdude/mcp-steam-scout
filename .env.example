# Steam — required
STEAM_API_KEY=your_steam_api_key
STEAM_ID=your_numeric_steam_id

# Steam — optional fallback (resolved to STEAM_ID at startup)
# STEAM_USERNAME=your_steam_vanity_username

# PlayStation — optional (enables get_psn_library tool)
# Get NPSSO from the `npsso` cookie on playstation.com after logging in.
PSN_NPSSO=your_psn_npsso_token

# Xbox — optional (enables get_xbox_library tool)
# Run `go run github.com/opdude/mcp-steam-scout/cmd/setup-xbox@latest` to get a refresh token.
XBOX_REFRESH_TOKEN=your_xbox_refresh_token

# Epic Games Store — optional (enables get_epic_library tool)
# Run `go run github.com/opdude/mcp-steam-scout/cmd/setup-epic@latest` to get a refresh token.
EPIC_REFRESH_TOKEN=your_epic_refresh_token
